{
  "expo": {
    "name": "Learner",
    "slug": "Lms",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.arun_rengamani.Lms"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "imageWidth": 150,
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#000000",
            "imageWidth": 150
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff",
            "imageWidth": 150,
            "dark": {
              "image": "./assets/images/splash-icon.png",
              "resizeMode": "contain",
              "backgroundColor": "#000000",
              "imageWidth": 150
            }
          },
          "android": {
            "image": "./assets/images/splash-icon.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff",
            "imageWidth": 150,
            "dark": {
              "image": "./assets/images/splash-icon.png",
              "resizeMode": "contain",
              "backgroundColor": "#000000",
              "imageWidth": 150
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "440cd09c-682f-403a-84da-da6c1314ae54"
      }
    },
    "owner": "sureshchakravarthi"
  }
}
